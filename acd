CREATE OR REPLACE FUNCTION update_player_count()
RETURNS TRIGGER AS $$
BEGIN
UPDATE "Sport"
SET "numPlayers" = COALESCE("numPlayers",0) + NEW."numberOfPlayers"
WHERE name = NEW."sportName";
RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER update_players
AFTER INSERT ON "Booking"
FOR EACH ROW
EXECUTE FUNCTION update_player_count();

