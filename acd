CREATE OR REPLACE FUNCTION prevent_duplicate_booking()
RETURNS TRIGGER AS $$
BEGIN
IF EXISTS (
SELECT 1 FROM "Booking"
WHERE "userId" = NEW."userId"
AND date = NEW.date
AND "startTime" = NEW."startTime"
)
THEN
RAISE EXCEPTION 'User already booked this slot';
END IF;
RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER booking_check
BEFORE INSERT ON "Booking"
FOR EACH ROW
EXECUTE FUNCTION prevent_duplicate_booking();


